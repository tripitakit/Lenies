<!DOCTYPE html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Lenies">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="flex flex-col h-screen overflow-hidden">
    <header class="lenies-navbar menu menu-horizontal w-full relative z-10 shrink-0 flex items-center gap-4 px-4 sm:px-6 lg:px-8">
      <.link href={~p"/"} class="lenies-logo font-semibold tracking-wide">Lenies</.link>
      <nav class="ml-auto flex items-center gap-4">
        <%= if @current_scope && @current_scope.user do %>
          <.link href={~p"/sandbox"}>Sandbox</.link>
          <.link href={~p"/users/settings"}>Settings</.link>
          <span class="user-email opacity-70">{@current_scope.user.email}</span>
          <.link href={~p"/users/log-out"} method="delete">Log out</.link>
        <% else %>
          <.link href={~p"/users/register"}>Register</.link>
          <.link href={~p"/users/log-in"}>Log in</.link>
        <% end %>
      </nav>
    </header>
    <main class="flex-1 min-h-0 overflow-hidden">
      {@inner_content}
    </main>
  </body>
</html>
